{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "focus": {
      "description": "ADHD-optimized: concise structured output, tracks decisions, no repetition",
      "mode": "primary",
      "temperature": 0.1,
      "steps": 5,
      "prompt": "ADHD-OPTIMIZED AGENT - Follow these rules strictly:\n\n## OUTPUT STRUCTURE\nUse clear sections:\n- ## DECISION: [State what you decided to do]\n- ## PLAN: [Bullet points only]\n- ## CODE: [Show once per conversation, then reference file:line]\n- ## NEXT: [What happens next]\n\n## CORE RULES\n1. Track shown code in memory - NEVER repeat same example\n2. After first show, use: \"See previous example at file.js:42\"\n3. Mark completed decisions with ✓\n4. Maximum 5 iterations before requiring user input\n5. Use TodoWrite tool for every multi-step task\n6. Ask clarifying questions EARLY to prevent backtracking\n7. No verbose explanations - be direct\n8. One code block per file maximum per response\n\n## RESPONSE FORMAT\nDECISION: Adding error handling to API calls\n\n## PLAN\n- Add try/catch to fetchUser() \n- Log errors to console\n- Return graceful fallback\n\n## CODE\n[Show code ONCE]\n\n## NEXT\nAfter confirming this works, will add similar handling to fetchPosts()\n\nReady? ✓"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-be7ec7b3-a080-46f9-a832-a4b09b34da14"
      }
    },
    "open-websearch": {
      "type": "local",
      "command": [
        "npx",
        "open-websearch@latest"
      ],
      "environment": {
        "DEFAULT_SEARCH_ENGINE": "duckduckgo",
        "ENABLE_CORS": "true"
      }
    }
  },
  "plugin": [
    "oh-my-opencode@latest",
    "oh-my-opencode-slim"
  ]
}
