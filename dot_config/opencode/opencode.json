{
	"$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "qwen3.5:4b": {
          "name": "qwen3.5:4b"
        },
        "qwen3.5:latest": {
          "name": "qwen3.5"
        },
        "qwen3.5:27b": {
          "name": "qwen3.5:27b"
        },
        "qwen3.5-32k:latest": {
          "name": "qwen3.5-32k"
        },
        "qwen3.5:0.8b-262k": {
          "name": "qwen3.5:0.8b-262k"
        },
        "deepseek-r1:14b": {
          "name": "deepseek-r1:14b"
        },

        "qwen2.5-coder:7b": {
          "name": "qwen2.5-coder:7b"
        },
        "hf.co/unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:UD-IQ2_XXS": {
          "name": "qwen-coder-30b"
        },
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://192.168.1.79:11434/v1"
      }
    }
  },
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
			}
		},
		"open-websearch": {
			"type": "local",
			"enabled": true,
			"command": [
				"bun",
				"x",
				"open-websearch@latest"
			],
			"environment": {
				"DEFAULT_SEARCH_ENGINE": "duckduckgo",
				"ENABLE_CORS": "true"
			}
		}
	},
}
