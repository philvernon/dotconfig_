{
	"$schema": "https://opencode.ai/config.json",
	"agent": {
		"assist": {
			"mode": "primary",
			"model": "github-copilot/gpt-5-mini",
			"tools": {
				"write": false,
				"edit": false,
				"bash": false
			}
		},
	},
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"CONTEXT7_API_KEY": "ctx7sk-be7ec7b3-a080-46f9-a832-a4b09b34da14"
			}
		},
		"open-websearch": {
			"type": "local",
			"command": [
				"npx",
				"open-websearch@latest"
			],
			"environment": {
				"DEFAULT_SEARCH_ENGINE": "duckduckgo",
				"ENABLE_CORS": "true"
			}
		}
	},
}
